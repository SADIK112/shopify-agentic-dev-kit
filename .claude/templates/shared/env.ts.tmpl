// app/shared/lib/env.ts
// THE ONLY place process.env is read in this codebase (enforced by check-architecture.mjs).
// All env vars are parsed and validated at startup via Zod.
// Consumers import `getEnv()` — they never read process.env directly.
//
// Security: this file is the boundary between "secrets exist" and "code runs".
// The agent never reads actual env values. At runtime, Zod validates presence
// and shape; missing vars throw with a clear field-level error immediately.

import { z } from "zod";

const envSchema = z.object({
  // ── Shopify app ─────────────────────────────────────────────────────────────
  SHOPIFY_API_KEY:    z.string().min(1),
  SHOPIFY_API_SECRET: z.string().min(32),
  SCOPES:             z.string().min(1),
  SHOPIFY_APP_URL:    z.string().url(),

  // ── Database ─────────────────────────────────────────────────────────────────
  DATABASE_URL:       z.string().url(),

  // ── Session ──────────────────────────────────────────────────────────────────
  SESSION_SECRET:     z.string().min(32, "SESSION_SECRET must be at least 32 characters"),

  // ── Runtime ──────────────────────────────────────────────────────────────────
  NODE_ENV: z.enum(["development", "test", "production"]).default("development"),

  // ── Optional ─────────────────────────────────────────────────────────────────
  // Add optional vars with .optional() or .default("..."):
  // LOG_LEVEL: z.enum(["debug", "info", "warn", "error"]).default("info"),
});

export type Env = z.infer<typeof envSchema>;

let _env: Env | undefined;

/**
 * Returns the validated environment config.
 * Throws on first call if any required variable is missing or malformed,
 * printing all field errors at once.
 */
export function getEnv(): Env {
  if (_env) return _env;

  const result = envSchema.safeParse(process.env);
  if (!result.success) {
    const errors = result.error.flatten().fieldErrors;
    const lines  = Object.entries(errors)
      .map(([k, v]) => `  ${k}: ${v?.join(", ")}`)
      .join("\n");
    throw new Error(`Invalid environment variables:\n${lines}`);
  }

  _env = result.data;
  return _env;
}

// ── Convenience accessors (typed, no raw process.env access downstream) ───────

export const isDev        = () => getEnv().NODE_ENV === "development";
export const isProd       = () => getEnv().NODE_ENV === "production";
export const isTest       = () => getEnv().NODE_ENV === "test";
